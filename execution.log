+    if not tasks:
+        print("рҹ“ӯ жҡӮж— д»»еҠЎ")
+        return
+
+    today = datetime.now().date()
+
+    due_tasks = []
+    for task in tasks:
+        due_date_str = task.get("due_date")
+        if due_date_str:
+            try:
+                due_date = datetime.strptime(due_date_str, "%Y-%m-%d").date()
+                if days is not None:
+                    end_date = today + timedelta(days=days)
+                    if due_date <= end_date:
+                        days_left = (due_date - today).days
+                        due_tasks.append((task, due_date, days_left))
+                else:
+                    days_left = (due_date - today).days
+                    due_tasks.append((task, due_date, days_left))
+            except ValueError:
+                continue
+
+    if not due_tasks:
+        if days is not None:
+            print(f"рҹ“ӯ жІЎжңү {days} еӨ©еҶ…еҲ°жңҹзҡ„д»»еҠЎ")
+        else:
+            print("рҹ“ӯ жІЎжңүеёҰжҲӘжӯўж—Ҙжңҹзҡ„д»»еҠЎ")
+        return
+
+    if sort_by == "priority":
+        priority_order = {"й«ҳ": 0, "дёӯ": 1, "дҪҺ": 2}
+        due_tasks.sort(
+            key=lambda x: (x[2], priority_order.get(x[0].get("priority", "дёӯ"), 1))
+        )
+    else:
+        due_tasks.sort(key=lambda x: x[2])
+
+    print("\nрҹ“… еҚіе°ҶеҲ°жңҹзҡ„д»»еҠЎ")
+    if days is not None:
+        print(f"ж—¶й—ҙиҢғеӣҙпјҡ{days} еӨ©еҶ…")
+    print("-" * 60)
+
+    priority_icons = {"й«ҳ": "рҹ”ҙ", "дёӯ": "рҹҹЎ", "дҪҺ": "рҹҹў"}
+    overdue_count = 0
+
+    for task, due_date, days_left in due_tasks:
+        status = "вң…" if task["done"] else "вӯ•"
+        priority = task.get("priority", "дёӯ")
+        priority_icon = priority_icons.get(priority, "рҹҹЎ")
+
+        if days_left < 0:
+            due_str = f"е·ІиҝҮжңҹ {abs(days_left)} еӨ©"
+            overdue_count += 1
+        elif days_left == 0:
+            due_str = "д»ҠеӨ©еҲ°жңҹ вҡ пёҸ"
+        elif days_left == 1:
+            due_str = "жҳҺеӨ©еҲ°жңҹ вҡ пёҸ"
+        else:
+            due_str = f"еү©дҪҷ {days_left} еӨ©"
+
+        print(
+            f"{status} [{task['id']}] {priority_icon} {task['content']} рҹ“… {task['due_date']} ({due_str})"
+        )
+
+    print("-" * 60)
+    print(f"жҖ»и®Ўпјҡ{len(due_tasks)} дёӘд»»еҠЎ", end="")
+    if overdue_count > 0:
+        print(f" | вҡ пёҸ е·ІиҝҮжңҹпјҡ{overdue_count} дёӘ", end="")
+    print()
+
