# иҝҗиЎҢзү№е®ҡжөӢиҜ•
python3 -m pytest test_cli_commands.py -v

# жүӢеҠЁжөӢиҜ• CLI
python3 todo.py --help
python3 todo.py list
python3 todo.py stats
python3 todo.py list --priority й«ҳ
python3 todo.py list --tag жөӢиҜ•
```
