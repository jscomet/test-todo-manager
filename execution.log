+def export_csv(filename=None):
+    """
+    еҜјеҮәд»»еҠЎеҲ—иЎЁдёә CSV ж јејҸ
+
+    Args:
+        filename (str): иҫ“еҮәж–Үд»¶еҗҚпјҢй»ҳи®Өдёә tasks_export.csv
+
+    Returns:
+        None
+
+    Note:
+        CSV еҢ…еҗ«еҲ—пјҡID, еҶ…е®№пјҢзҠ¶жҖҒпјҢдјҳе…Ҳзә§пјҢеҲӣе»әж—¶й—ҙпјҢжҲӘжӯўж—ҘжңҹпјҢж Үзӯҫ
+    """
+    import csv
+
+    tasks = load_tasks()
+    if not tasks:
+        print("рҹ“ӯ жҡӮж— д»»еҠЎеҸҜеҜјеҮә")
+        return
+
+    if filename is None:
+        filename = "tasks_export.csv"
+
+    with open(filename, "w", encoding="utf-8-sig", newline="") as f:
+        writer = csv.writer(f)
+        writer.writerow(
+            ["ID", "еҶ…е®№", "зҠ¶жҖҒ", "дјҳе…Ҳзә§", "еҲӣе»әж—¶й—ҙ", "жҲӘжӯўж—Ҙжңҹ", "ж Үзӯҫ"]
+        )
+        for task in tasks:
+            status = "е·Іе®ҢжҲҗ" if task["done"] else "еҫ…е®ҢжҲҗ"
+            tags = ", ".join(task.get("tags", []))
+            writer.writerow(
+                [
+                    task["id"],
+                    task["content"],
+                    status,
+                    task.get("priority", "дёӯ"),
+                    task.get("created_at", ""),
+                    task.get("due_date", ""),
+                    tags,
+                ]
+            )
+    print(f"вң… е·ІеҜјеҮә {len(tasks)} дёӘд»»еҠЎеҲ°пјҡ{filename}")
+
+
+def export_markdown(filename=None):
+    """
