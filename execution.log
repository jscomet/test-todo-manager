python3 todo.py add "普通任务" -p 中
python3 todo.py add "不紧急任务" -p 低
python3 todo.py add "默认任务"  # 默认中优先级

# 查看任务列表
python3 todo.py list

# 查看帮助
python3 todo.py add --help
